{
  "name": "claude-code-toolkit",
  "version": "1.0.0",
  "description": "Claude Code Toolkit - Agent Skills for automation and development workflows",
  "private": true,
  "workspaces": [
    ".claude/skills/utils",
    ".claude/skills/code-quality-suite",
    ".claude/skills/technical-blog-generator",
    ".claude/skills/spec-driven-development",
    ".claude/skills/aws-cost-optimizer",
    ".claude/skills/serverless-optimizer",
    ".claude/skills/database-manager",
    ".claude/skills/aws-deploy-automation",
    ".claude/skills/ai-prompt-manager",
    ".claude/skills/api-contract-validator",
    ".claude/skills/e2e-test-generator",
    ".claude/skills/frontend-performance-auditor"
  ],
  "scripts": {
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "eslint \".claude/skills/**/*.js\"",
    "lint:fix": "eslint \".claude/skills/**/*.js\" --fix",
    "format": "prettier --write \".claude/skills/**/*.{js,json,md}\"",
    "format:check": "prettier --check \".claude/skills/**/*.{js,json,md}\""
  },
  "keywords": [
    "claude",
    "claude-code",
    "agent-skills",
    "automation",
    "aws",
    "ai",
    "testing",
    "performance"
  ],
  "author": "Claude Code Toolkit",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^8.57.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.29.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.0"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
