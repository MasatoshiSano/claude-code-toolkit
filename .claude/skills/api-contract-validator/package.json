{
  "name": "@claude-code-toolkit/api-contract-validator",
  "version": "1.0.0",
  "description": "API contract validation with OpenAPI/Swagger support",
  "main": "scripts/index.js",
  "type": "module",
  "scripts": {
    "test": "jest",
    "generate": "node scripts/generate-openapi.js",
