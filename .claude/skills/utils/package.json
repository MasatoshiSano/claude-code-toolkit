{
  "name": "@claude-code-toolkit/utils",
  "version": "1.0.0",
  "description": "Common utilities for Claude Code Agent Skills",
  "main": "index.js",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "keywords": [
    "claude",
    "agent-skills",
    "utilities",
    "logger",
    "error-handling"
  ],
  "author": "Claude Code Toolkit",
  "license": "MIT",
  "homepage": "https://github.com/claude-code-toolkit/claude-code-toolkit#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/claude-code-toolkit/claude-code-toolkit.git",
    "directory": ".claude/skills/utils"
  },
  "bugs": {
    "url": "https://github.com/claude-code-toolkit/claude-code-toolkit/issues"
  },
  "dependencies": {
    "winston": "^3.11.0",
    "yargs": "^17.7.2",
    "cli-progress": "^3.12.0",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "jest": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "*.js",
      "!index.js",
      "!jest.config.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  }
}
