{
  "name": "@claude-code-toolkit/ai-prompt-manager",
  "version": "1.0.0",
  "description": "AI prompt management with A/B testing and optimization",
  "main": "scripts/index.js",
  "type": "module",
  "scripts": {
    "test": "jest",
    "ab-test": "node scripts/ab-test-runner.js",
    "optimize": "node scripts/token-optimizer.js",
    "analyze": "node scripts/performance-analyzer.js"
  },
  "keywords": [
    "ai",
    "prompt",
    "anthropic",
    "openai",
    "ab-testing",
    "optimization"
  ],
  "author": "Claude Code Toolkit",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.20.0",
    "openai": "^4.28.0",
    "tiktoken": "^1.0.0",
    "@claude-code-toolkit/utils": "^1.0.0"
  },
  "devDependencies": {
    "jest": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "scripts/**/*.js",
      "!scripts/index.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  },
  "homepage": "https://github.com/claude-code-toolkit/claude-code-toolkit#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/claude-code-toolkit/claude-code-toolkit.git",
    "directory": ".claude/skills/ai-prompt-manager"
  },
  "bugs": {
    "url": "https://github.com/claude-code-toolkit/claude-code-toolkit/issues"
  }
}
