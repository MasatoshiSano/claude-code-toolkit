{
  "version": "1.0.0",
  "description": "Recommended ESLint rules for code quality suite",
  "recommendedRules": {
    "errors": {
      "no-console": "error",
      "no-debugger": "error",
      "no-unused-vars": "error",
      "no-undef": "error",
      "no-dupe-keys": "error",
      "no-duplicate-case": "error",
      "no-unreachable": "error"
    },
    "bestPractices": {
      "eqeqeq": ["error", "always"],
      "no-eval": "error",
      "no-implied-eval": "error",
      "no-new-func": "error",
      "no-return-await": "error",
      "prefer-const": "error",
      "no-var": "error"
    },
    "codeStyle": {
      "indent": ["warn", 2],
      "quotes": ["warn", "single"],
      "semi": ["warn", "always"],
      "comma-dangle": ["warn", "always-multiline"]
    }
  },
  "severityLevels": {
    "error": "Must be fixed before deployment",
    "warn": "Should be addressed",
    "off": "Not enforced"
  }
}
