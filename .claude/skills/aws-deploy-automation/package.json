{
  "name": "@claude-code-toolkit/aws-deploy-automation",
  "version": "1.0.0",
  "description": "AWS deployment automation with CDK, CloudFormation, and Terraform support",
  "main": "scripts/index.js",
  "type": "module",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "deploy:cdk": "node scripts/deploy-cdk.js",
    "deploy:cfn": "node scripts/deploy-cloudformation.js",
    "deploy:terraform": "node scripts/deploy-terraform.js",
    "rollback": "node scripts/rollback-stack.js",
    "validate": "node scripts/pre-deploy-validation.js",
    "smoke-test": "node scripts/post-deploy-smoke-test.js"
  },
  "keywords": [
    "aws",
    "deployment",
    "cdk",
    "cloudformation",
    "terraform",
    "agent-skills",
    "infrastructure",
    "iac"
  ],
  "author": "Claude Code Toolkit",
  "license": "MIT",
  "homepage": "https://github.com/claude-code-toolkit/claude-code-toolkit#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/claude-code-toolkit/claude-code-toolkit.git",
    "directory": ".claude/skills/aws-deploy-automation"
  },
  "bugs": {
    "url": "https://github.com/claude-code-toolkit/claude-code-toolkit/issues"
  },
  "dependencies": {
    "@aws-sdk/client-cloudformation": "^3.600.0",
    "@aws-sdk/client-ec2": "^3.600.0",
    "@aws-sdk/client-ecs": "^3.600.0",
    "@aws-sdk/client-lambda": "^3.600.0",
    "@aws-sdk/client-rds": "^3.600.0",
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/client-secrets-manager": "^3.600.0",
    "@aws-sdk/client-sts": "^3.600.0",
    "@aws-sdk/client-cloudwatch": "^3.600.0",
    "aws-cdk-lib": "^2.140.0",
    "@claude-code-toolkit/utils": "^1.0.0",
    "constructs": "^10.3.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "@types/node": "^20.12.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "scripts/**/*.js",
      "!scripts/index.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  }
}
