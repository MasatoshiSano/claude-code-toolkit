# Claude Code Toolkit - Environment Variables Template
# コピーして .env ファイルを作成してください: cp .env.example .env
# ⚠️ 重要: .env ファイルは絶対にGitにコミットしないでください！

# ========================================
# AWS Credentials
# ========================================
# AWS Cost Optimizer, Serverless Optimizer, AWS Deploy Automation で使用
# IAMユーザーまたはAssumeRoleで取得したクレデンシャルを設定

# オプション1: AWS Access Keys（開発環境のみ推奨）
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_DEFAULT_REGION=us-east-1

# オプション2: AWS Profile（推奨）
# AWS_PROFILE=your-profile-name

# オプション3: AWS IAM Role (EC2/ECSで実行する場合)
# IAMロールを使用する場合は上記の設定は不要です

# ========================================
# Anthropic API (Claude)
# ========================================
# AI Prompt Manager で使用
# 取得方法: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ========================================
# OpenAI API
# ========================================
# AI Prompt Manager でOpenAIモデルを使用する場合
# 取得方法: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ========================================
# Database Configuration
# ========================================
# Database Manager で使用

# PostgreSQL
DATABASE_URL=postgresql://username:password@localhost:5432/dbname

# MySQL
# DATABASE_URL=mysql://username:password@localhost:3306/dbname

# MongoDB
# MONGODB_URI=mongodb://username:password@localhost:27017/dbname

# ========================================
# Notification Services
# ========================================

# Slack Webhook（コスト超過アラートなど）
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# SendGrid API Key（メール通知）
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# AWS SES（メール通知の代替）
SES_FROM_EMAIL=noreply@yourdomain.com
SES_TO_EMAIL=alerts@yourdomain.com

# ========================================
# CI/CD Integration
# ========================================

# GitHub Token（GitHub Actions、自動PR作成など）
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# GitLab Token
# GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx

# ========================================
# Monitoring & Logging
# ========================================

# Datadog API Key
# DATADOG_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# New Relic License Key
# NEW_RELIC_LICENSE_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ========================================
# Testing & Development
# ========================================

# Jestのタイムアウト設定（ms）
JEST_TIMEOUT=30000

# ログレベル (debug, info, warn, error)
LOG_LEVEL=info

# 開発モード
NODE_ENV=development

# ========================================
# Optional: Terraform/CDK Configuration
# ========================================

# Terraform Cloud Token
# TF_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# CDK Bootstrap用のアカウントID
# CDK_DEFAULT_ACCOUNT=123456789012
# CDK_DEFAULT_REGION=us-east-1
